{
  "manifest_version": 3,
  "name": "NINA",
  "short_name": "NINA",
  "version": "3.1.1",
  "version_name": "3.1.1",
  "description": "NINA — Speed-, Audio-Boost & Auto-Skip für Joyn, YouTube, Netflix, Disney+. Mit Auto-Like, SponsorBlock & Dislike-Anzeige.",
  "author": "NINA",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "sidePanel"],
  "host_permissions": [
    "*://*.joyn.de/*",
    "*://*.glomex.com/*",
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.de/video/*",
    "*://*.amazon.com/video/*",
    "*://*.amazon.co.uk/video/*",
    "*://*.disneyplus.com/*",
    "*://*.crunchyroll.com/*",
    "*://*.dazn.com/*",
    "*://*.twitch.tv/*",
    "*://*.ardmediathek.de/*",
    "*://*.zdf.de/*",
    "*://*.zdfmediathek.de/*",
    "*://*.rtl.de/*",
    "*://*.rtlplus.com/*",
    "*://*.tvnow.de/*",
    "*://*.mubi.com/*",
    "*://tv.apple.com/*",
    "*://*.paramount.com/*",
    "*://*.paramountplus.com/*",
    "*://*.peacocktv.com/*",
    "*://*.hbo.com/*",
    "*://*.max.com/*",
    "*://*.hulu.com/*",
    "*://*.vimeo.com/*",
    "*://*.dailymotion.com/*",
    "*://*.ard.de/*",
    "*://*.3sat.de/*",
    "*://*.arte.tv/*",
    "*://*.funimation.com/*",
    "*://*.hidive.com/*",
    "*://*.wakanim.tv/*",
    "https://sponsor.ajay.app/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.joyn.de/*",
        "*://*.glomex.com/*",
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.de/video/*",
        "*://*.amazon.com/video/*",
        "*://*.amazon.co.uk/video/*",
        "*://*.disneyplus.com/*",
        "*://*.crunchyroll.com/*",
        "*://*.dazn.com/*",
        "*://*.twitch.tv/*",
        "*://*.ardmediathek.de/*",
        "*://*.zdf.de/*",
        "*://*.zdfmediathek.de/*",
        "*://*.rtl.de/*",
        "*://*.rtlplus.com/*",
        "*://*.tvnow.de/*",
        "*://*.mubi.com/*",
        "*://tv.apple.com/*",
        "*://*.paramount.com/*",
        "*://*.paramountplus.com/*",
        "*://*.peacocktv.com/*",
        "*://*.hbo.com/*",
        "*://*.max.com/*",
        "*://*.hulu.com/*",
        "*://*.vimeo.com/*",
        "*://*.dailymotion.com/*",
        "*://*.ard.de/*",
        "*://*.3sat.de/*",
        "*://*.arte.tv/*",
        "*://*.funimation.com/*",
        "*://*.hidive.com/*",
        "*://*.wakanim.tv/*"
      ],
      "js": ["content/speed-patch.js", "content/audio-patch.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.joyn.de/*",
        "*://*.glomex.com/*",
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.de/video/*",
        "*://*.amazon.com/video/*",
        "*://*.amazon.co.uk/video/*",
        "*://*.disneyplus.com/*",
        "*://*.crunchyroll.com/*",
        "*://*.dazn.com/*",
        "*://*.twitch.tv/*",
        "*://*.ardmediathek.de/*",
        "*://*.zdf.de/*",
        "*://*.zdfmediathek.de/*",
        "*://*.rtl.de/*",
        "*://*.rtlplus.com/*",
        "*://*.tvnow.de/*",
        "*://*.mubi.com/*",
        "*://tv.apple.com/*",
        "*://*.paramount.com/*",
        "*://*.paramountplus.com/*",
        "*://*.peacocktv.com/*",
        "*://*.hbo.com/*",
        "*://*.max.com/*",
        "*://*.hulu.com/*",
        "*://*.vimeo.com/*",
        "*://*.dailymotion.com/*",
        "*://*.ard.de/*",
        "*://*.3sat.de/*",
        "*://*.arte.tv/*",
        "*://*.funimation.com/*",
        "*://*.hidive.com/*",
        "*://*.wakanim.tv/*"
      ],
      "js": ["content/frame-speed.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.joyn.de/*"],
      "js": ["content/joyn.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.de/video/*",
        "*://*.amazon.com/video/*",
        "*://*.amazon.co.uk/video/*",
        "*://*.disneyplus.com/*",
        "*://*.crunchyroll.com/*",
        "*://*.dazn.com/*",
        "*://*.twitch.tv/*",
        "*://*.ardmediathek.de/*",
        "*://*.zdf.de/*",
        "*://*.zdfmediathek.de/*",
        "*://*.rtl.de/*",
        "*://*.rtlplus.com/*",
        "*://*.tvnow.de/*",
        "*://*.mubi.com/*",
        "*://tv.apple.com/*",
        "*://*.paramount.com/*",
        "*://*.paramountplus.com/*",
        "*://*.peacocktv.com/*",
        "*://*.hbo.com/*",
        "*://*.max.com/*",
        "*://*.hulu.com/*",
        "*://*.vimeo.com/*",
        "*://*.dailymotion.com/*",
        "*://*.ard.de/*",
        "*://*.3sat.de/*",
        "*://*.arte.tv/*",
        "*://*.funimation.com/*",
        "*://*.hidive.com/*",
        "*://*.wakanim.tv/*"
      ],
      "js": ["content/universal.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/youtube-dislike.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "action": {
    "default_title": "NINA",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
